// Module 16 — Prisma schema.
//
// This module is self-contained: it does NOT use the repo-wide `packages/db`
// client. It has its OWN schema here and generates its client into a local
// `generated/client` directory (Prisma 7 requires an explicit `output`), which
// every `src/*`, `solution/*` and `test/*` file imports. Generation runs on
// `pnpm install` via the package's `prepare` script.
//
// Datasource is SQLite so the test gate is fast + deterministic with no Docker.
// Prisma abstracts the engine — the modelling, relations, nested reads/writes,
// transactions and N+1 concepts are identical on Postgres.
//
// The connection string comes from env `DATABASE_URL`, wired up in
// `prisma.config.ts` (for the CLI) and the `PrismaBetterSQLite3` driver adapter
// (at runtime). The test harness sets it to a per-file temp file (e.g.
// `file:./.tmp-test-01.db`) before `db push`.

datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client"
  output   = "../generated/client"
}

model User {
  id     Int     @id @default(autoincrement())
  email  String  @unique
  name   String
  boards Board[]
}

model Board {
  id      Int    @id @default(autoincrement())
  title   String
  owner   User   @relation(fields: [ownerId], references: [id])
  ownerId Int
  lists   List[]
}

model List {
  id       Int    @id @default(autoincrement())
  title    String
  position Int
  board    Board  @relation(fields: [boardId], references: [id])
  boardId  Int
  cards    Card[]

  // Compound (double-@) index: reads always filter a board's lists in position
  // order, so `(boardId, position)` lets SQLite satisfy the WHERE + ORDER BY
  // from one index instead of scanning + sorting.
  @@index([boardId, position])
}

model Card {
  id       Int    @id @default(autoincrement())
  title    String
  position Int
  list     List   @relation(fields: [listId], references: [id])
  listId   Int

  // Task 4's compound index: `card.findMany({ where: { listId }, orderBy: { position } })`
  // is the hot path behind the N+1 fix — this index covers it.
  @@index([listId, position])
}
