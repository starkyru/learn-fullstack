// The single shared schema for the whole course. Domain slices (kanban, chat) are added
// by the modules/apps that need them; Phase 0 ships only User so migrations work.
generator client {
  provider = "prisma-client-js"
  // Emit to a package-local dir, NOT the default node_modules/.prisma/client — module 16
  // teaches Prisma against a throwaway SQLite schema and generates to that default location,
  // which would otherwise clobber this shared Postgres client (and break `db:seed`).
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
}
