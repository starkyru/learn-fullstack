// The single shared schema for the whole course. Domain slices (kanban, chat) are added
// by the modules/apps that need them; Phase 0 ships only User so migrations work.
generator client {
  // Prisma 7 generator: emits plain TypeScript. `output` is required — we keep it
  // package-local so module 16's own throwaway SQLite client (generated inside that
  // module) can never clobber this shared Postgres client (or break `db:seed`).
  provider = "prisma-client"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  // Prisma 7: the connection URL lives in prisma.config.ts (for the CLI) and in the
  // PrismaPg driver adapter (at runtime), not in the schema.
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
}
